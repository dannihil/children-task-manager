{
  "expo": {
    "name": "TaskyKids",
    "slug": "children-task-manager",
    "version": "1.0.6",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/79c0b60d-cab9-4c7f-b95e-f05e2c68bd86"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.childrentaskmanager.app",
      "buildNumber": "13",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "versionCode": 3,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-localization",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow access to your photo library to choose a profile picture.",
          "cameraPermission": "Allow camera access to take a profile picture."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "79c0b60d-cab9-4c7f-b95e-f05e2c68bd86"
      },
      "parentNotifyUrl": "https://children-task-manager.vercel.app/api/parent-notify",
      "parentNotifySecret": ""
    }
  }
}
