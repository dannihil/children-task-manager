# --- Vercel (or any host running api/parent-notify.js) ---
RESEND_API_KEY=re_xxxxxxxx
# Verified domain sender, or for Resend trial: TaskyKids <onboarding@resend.dev>
RESEND_FROM=TaskyKids <onboarding@resend.dev>
# Optional; default display name is TaskyKids (rebuilds From even if RESEND_FROM still says old app name)
# RESEND_FROM_NAME=
# Optional; full URL to signature PNG (default: https://$VERCEL_URL/taskykids-email-signature.png)
# EMAIL_SIGNATURE_IMAGE_URL=
# Optional: same value as app extra EXPO_PUBLIC_PARENT_NOTIFY_SECRET / parentNotifySecret
PARENT_NOTIFY_SECRET=

# --- Expo app (optional; or set parentNotifyUrl / parentNotifySecret in app.json) ---
# EXPO_PUBLIC_PARENT_NOTIFY_URL=https://your-project.vercel.app/api/parent-notify
# EXPO_PUBLIC_PARENT_NOTIFY_SECRET=
